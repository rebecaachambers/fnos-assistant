<Window x:Class="FnosAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FnosAssistant"
        xmlns:vm="clr-namespace:FnosAssistant.ViewModels"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d"
        Title="Fnos assistant"
        Height="540" Width="700"
        MinHeight="400" MinWidth="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F5F5">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Fnos assistant"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#2C3E50" />
            <TextBlock Text="搜索局域网内的飞牛 OS 设备并快速登录"
                       FontSize="13" Foreground="#7F8C8D"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Controls -->
        <DockPanel Grid.Row="1" Margin="0,0,0,12">
            <Button Content="🔍 扫描设备"
                    Command="{Binding ScanCommand}"
                    IsEnabled="{Binding IsScanning, Converter={StaticResource BoolInvertConverter}}"
                    Width="120" Height="34"
                    Background="#3498DB" Foreground="White"
                    BorderThickness="0" FontSize="14"
                    Cursor="Hand"
                    DockPanel.Dock="Left">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            Padding="16,6">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Resources>
            </Button>
            <TextBlock Text="{Binding StatusText}"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"
                       FontSize="13" Foreground="#555" />
        </DockPanel>

        <!-- Device List -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                BorderBrush="#DDD" BorderThickness="1">
            <ListView ItemsSource="{Binding Devices}"
                      SelectedItem="{Binding SelectedDevice}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      Margin="0" MouseDoubleClick="ListViewItem_DoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="" Width="48">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="🖥️" FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="设备名称" Width="200">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DeviceName}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#2C3E50"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="IP 地址" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding IpAddress}"
                                               FontSize="13" Foreground="#555"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="4,6" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Border>


    </Grid>
</Window>
